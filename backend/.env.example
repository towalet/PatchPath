# ---------------------------------------------------------------------------
# PatchPath backend environment. Copy to `.env` and fill in real values.
# Never commit the real .env file.
# ---------------------------------------------------------------------------

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# Database (docker-compose injects DB_HOST=db at runtime)
DB_NAME=patchpath
DB_USER=patchpath
DB_PASSWORD=patchpath
DB_HOST=localhost
DB_PORT=5432
# Alternatively set a single DATABASE_URL (takes precedence over DB_* above):
# DATABASE_URL=postgres://patchpath:patchpath@localhost:5432/patchpath

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# CORS (frontend dev origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI (OpenAI-compatible). Leave OPENAI_API_KEY blank to run the deterministic
# pipeline only; reports then fall back to a low-confidence detector summary.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
PATCHPATH_AI_MODEL=gpt-4o-mini
PATCHPATH_AI_TIMEOUT=45
PATCHPATH_AI_MAX_RETRIES=1
PATCHPATH_AI_TEMPERATURE=0.2

# Upload + evidence limits
PATCHPATH_MAX_FILE_BYTES=1048576
PATCHPATH_MAX_SESSION_BYTES=5242880
PATCHPATH_EVIDENCE_CHAR_BUDGET=12000

# --- Compose-only Postgres bootstrap (used by the db service) ---------------
POSTGRES_USER=patchpath
POSTGRES_PASSWORD=patchpath
POSTGRES_DB=patchpath
